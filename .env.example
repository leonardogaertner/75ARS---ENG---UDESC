# .env.example - Variáveis de Ambiente para Desenvolvimento Local

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin_password
POSTGRES_DB=microsservicos_db

# Serviço de Clientes (Node.js)
CLIENTES_DB_HOST=postgres-db
CLIENTES_DB_PORT=5432
CLIENTES_DB_USER=admin
CLIENTES_DB_PASSWORD=admin_password
CLIENTES_DB_NAME=microsservicos_db
CLIENTES_DB_SCHEMA=clientes
NODE_ENV=production

# Serviço de Produtos (Spring Boot)
PRODUTOS_DB_HOST=postgres-db
PRODUTOS_DB_PORT=5432
PRODUTOS_DB_USER=admin
PRODUTOS_DB_PASSWORD=admin_password
PRODUTOS_DB_NAME=microsservicos_db
PRODUTOS_DB_SCHEMA=produtos

# Serviço de Pedidos (Spring Boot)
PEDIDOS_DB_HOST=postgres-db
PEDIDOS_DB_PORT=5432
PEDIDOS_DB_USER=admin
PEDIDOS_DB_PASSWORD=admin_password
PEDIDOS_DB_NAME=microsservicos_db
PEDIDOS_DB_SCHEMA=pedidos

# API Gateway
GATEWAY_PORT=8080
GATEWAY_WORKERS=4
